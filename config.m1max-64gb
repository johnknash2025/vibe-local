# vibe-local configuration — Apple M1 Max / 64GB RAM
# Copy to ~/.config/vibe-local/config or use with --config

# Main model: qwen3:30b (18GB, fits well in 64GB unified memory)
MODEL="qwen3:30b"

# Sidecar model: gpt-oss:20b (13GB, fast for lightweight tasks)
SIDECAR_MODEL="gpt-oss:20b"

# Ollama endpoint
OLLAMA_HOST="http://localhost:11434"

# Context window for qwen3:30b
CONTEXT_WINDOW="32768"

# Max output tokens
MAX_TOKENS="8192"

# Sampling temperature
TEMPERATURE="0.7"
